#Область ПрограммныйИнтерфейс

// Создает новую сессию чата.
//
// Параметры:
//  ТекстПервогоСообщения - Строка - текст первого сообщения пользователя.
//  КонтекстОбъектаJSON - Строка - JSON с контекстом объекта (опционально).
//  ОбъектКонтекста - ОпределяемыйТип.ИИ_ТипыОбъектовКонтекстныхЗапросов - объект контекста (опционально).
//
// Возвращаемое значение:
//  СправочникСсылка.ИИ_СессииЧатов - ссылка на созданную сессию.
//
Функция СоздатьСессию(
 		Знач ТекстПервогоСообщения = "",
 		Знач КонтекстОбъектаJSON = "",
 		Знач ОбъектКонтекста = Неопределено) Экспорт
 	
 	НоваяСессия = Справочники.ИИ_СессииЧатов.СоздатьЭлемент();
  	НоваяСессия.Наименование = "Новый чат";
  	НоваяСессия.Пользователь = ИмяПользователя();
  	НоваяСессия.КонтекстОбъектаJSON = КонтекстОбъектаJSON;
  	НоваяСессия.ОбъектКонтекста = ОбъектКонтекста;
  	НоваяСессия.Контекстный = ЗначениеЗаполнено(ОбъектКонтекста)
  		Или ЗначениеЗаполнено(КонтекстОбъектаJSON);
  	НоваяСессия.Записать();
 	
 	Возврат НоваяСессия.Ссылка;
 	
 КонецФункции

// Формирует JSON-описание объекта для передачи в шлюз как контекст.
//
// Параметры:
//  ОбъектСсылка - ЛюбаяСсылка - ссылка на объект, для которого нужно получить контекст.
//
// Возвращаемое значение:
//  Строка - JSON-строка с полями type, name, synonym, presentation, ref, guid, attributes.
//
Функция ПолучитьКонтекстОбъекта(Знач ОбъектСсылка) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("type", Строка(ТипЗнч(ОбъектСсылка)));
	Результат.Вставить("name", ОбъектСсылка.Метаданные().Имя);
	Результат.Вставить("synonym", Строка(ОбъектСсылка.Метаданные().ПредставлениеОбъекта));
	Результат.Вставить("presentation", Строка(ОбъектСсылка));
	Результат.Вставить("ref", Строка(ОбъектСсылка));
	Результат.Вставить("guid", Строка(ОбъектСсылка.УникальныйИдентификатор()));
	
	Атрибуты = Новый Массив;
	Для Каждого Реквизит Из ОбъектСсылка.Метаданные().Реквизиты Цикл
		Попытка
			ЗначениеРеквизита = ОбъектСсылка[Реквизит.Имя];
			ОписаниеРеквизита = Новый Структура;
			ОписаниеРеквизита.Вставить("name", Реквизит.Имя);
			ОписаниеРеквизита.Вставить("synonym", Строка(Реквизит.Представление()));
			ОписаниеРеквизита.Вставить("value", Строка(ЗначениеРеквизита));
			Атрибуты.Добавить(ОписаниеРеквизита);
		Исключение
			// Реквизит недоступен по ссылке - пропускаем.
			ЗаписьЖурналаРегистрации("ИИ_Ассистент.ПолучитьКонтекстОбъекта", УровеньЖурналаРегистрации.Предупреждение, , , ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецПопытки;
	КонецЦикла;
	Результат.Вставить("attributes", Атрибуты);
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Результат);
	Возврат ЗаписьJSON.Закрыть();
	
КонецФункции

// Запускает фоновое задание для выполнения запроса к шлюзу ИИ-ассистента.
// Результат фонового задания помещается во временное хранилище по адресу,
// который возвращается вместе с идентификатором задания.
//
// Параметры:
//  АдресШлюза - Строка - адрес шлюза в формате "host:port".
//  Таймаут - Число - таймаут соединения в секундах.
//  Модель - Строка - имя модели.
//  ТекстВопроса - Строка - текст вопроса пользователя.
//  История - Массив - история сообщений.
//  КонтекстОбъектаJSON - Строка - JSON с контекстом объекта.
//  ПромптПодсказка - Строка - дополнительная подсказка.
//  Вложения - Массив - вложения.
//  Сессия - СправочникСсылка.ИИ_СессииЧатов - сессия, для которой выполняется запрос (для оповещения).
//
// Возвращаемое значение:
//  Структура - данные запущенного задания:
//   * ИдентификаторЗадания - Строка - UUID фонового задания.
//   * АдресХранилища - Строка - адрес временного хранилища для получения результата.
//
Функция ЗапуститьЗапросКШлюзу(
		Знач АдресШлюза,
		Знач Таймаут,
		Знач ТекстВопроса,
		Знач История,
		Знач КонтекстОбъектаJSON = "",
		Знач ПромптПодсказка = "",
		Знач Вложения = Неопределено,
		Знач Сессия = Неопределено) Экспорт
	
	// Создаем временное хранилище в сеансе, инициировавшем фоновое задание.
	// Фоновое задание запишет результат по этому адресу.
	АдресХранилища = ПоместитьВоВременноеХранилище(Неопределено);
	
	Параметры = Новый Массив;
	Параметры.Добавить(АдресШлюза);
	Параметры.Добавить(Таймаут);
	Параметры.Добавить(ТекстВопроса);
	Параметры.Добавить(История);
	Параметры.Добавить(КонтекстОбъектаJSON);
	Параметры.Добавить(ПромптПодсказка);
	Параметры.Добавить(Вложения);
	Параметры.Добавить(АдресХранилища);
	Параметры.Добавить(Сессия);
	
	ФоновоеЗадание = ФоновыеЗадания.Выполнить("ИИ_АссистентСервер.ВыполнитьЗапросКШлюзу", Параметры);
	
	Результат = Новый Структура;
	Результат.Вставить("ИдентификаторЗадания", Строка(ФоновоеЗадание.УникальныйИдентификатор));
	Результат.Вставить("АдресХранилища", АдресХранилища);
	
	Возврат Результат;
	
КонецФункции

// Проверяет состояние фонового задания и возвращает его результат из временного хранилища.
//
// Параметры:
//  ИдентификаторЗадания - Строка - UUID фонового задания.
//  АдресХранилища - Строка - адрес временного хранилища, куда фоновое задание поместит результат.
//
// Возвращаемое значение:
//  Структура - результат проверки:
//   * Статус - Строка - "Выполняется", "Завершено", "Ошибка", "НеНайдено".
//   * Успешно - Булево - признак успешного выполнения (актуально при Статус = "Завершено").
//   * Ответ - Строка - текст ответа шлюза.
//   * СообщениеОбОшибке - Строка - описание ошибки.
//
Функция ПроверитьФоновоеЗадание(Знач ИдентификаторЗадания, Знач АдресХранилища) Экспорт
	
	Результат = Новый Структура("Статус, Успешно, Ответ, СообщениеОбОшибке", "НеНайдено", Ложь, "", "");
	
	Попытка
		UUID = Новый УникальныйИдентификатор(ИдентификаторЗадания);
	Исключение
		Результат.Статус = "Ошибка";
		Результат.СообщениеОбОшибке = "Некорректный идентификатор фонового задания.";
		Возврат Результат;
	КонецПопытки;
	
	ФоновоеЗадание = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(UUID);
	Если ФоновоеЗадание = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если ФоновоеЗадание.Состояние = СостояниеФоновогоЗадания.Активно Тогда
		Результат.Статус = "Выполняется";
	ИначеЕсли ФоновоеЗадание.Состояние = СостояниеФоновогоЗадания.ЗавершеноАварийно Тогда
		Результат.Статус = "Ошибка";
		Результат.СообщениеОбОшибке = "Фоновое задание завершилось с ошибкой.";
		Если ФоновоеЗадание.ИнформацияОбОшибке <> Неопределено Тогда
			Результат.СообщениеОбОшибке = Результат.СообщениеОбОшибке + " " + ФоновоеЗадание.ИнформацияОбОшибке.Описание;
		КонецЕсли;
	ИначеЕсли ФоновоеЗадание.Состояние = СостояниеФоновогоЗадания.Отменено Тогда
		Результат.Статус = "Ошибка";
		Результат.СообщениеОбОшибке = "Фоновое задание отменено.";
	Иначе
		Результат.Статус = "Завершено";
		РезультатРаботы = ПолучитьИзВременногоХранилища(АдресХранилища);
		Если ТипЗнч(РезультатРаботы) = Тип("Структура") Тогда
			РезультатРаботы.Свойство("Успешно", Результат.Успешно);
			РезультатРаботы.Свойство("Ответ", Результат.Ответ);
			РезультатРаботы.Свойство("СообщениеОбОшибке", Результат.СообщениеОбОшибке);
		Иначе
			Результат.СообщениеОбОшибке = "Фоновое задание не вернуло результат.";
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Отменяет фоновое задание по UUID.
//
// Параметры:
//  ИдентификаторЗадания - Строка - UUID фонового задания.
//
Процедура ОтменитьФоновоеЗадание(Знач ИдентификаторЗадания) Экспорт
	
	Попытка
		UUID = Новый УникальныйИдентификатор(ИдентификаторЗадания);
		ФоновоеЗадание = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(UUID);
		Если ФоновоеЗадание <> Неопределено
			И ФоновоеЗадание.Состояние = СостояниеФоновогоЗадания.Активно Тогда
			ФоновоеЗадание.Отменить();
		КонецЕсли;
	Исключение
		// Игнорируем ошибки отмены, но оставляем оператор для синтаксической проверки.
		ЗаписьЖурналаРегистрации("ИИ_Ассистент.ОтменитьФоновоеЗадание", УровеньЖурналаРегистрации.Предупреждение, , , ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
КонецПроцедуры

// Выполняет запрос к шлюзу ИИ-ассистента в фоновом задании.
// Результат запроса помещается во временное хранилище по переданному адресу.
//
// Параметры:
//  АдресШлюза - Строка - адрес шлюза в формате "host:port".
//  Таймаут - Число - таймаут соединения в секундах.
//  Модель - Строка - имя модели.
//  ТекстВопроса - Строка - текст вопроса пользователя.
//  История - Массив - история сообщений.
//  КонтекстОбъектаJSON - Строка - JSON с контекстом объекта.
//  ПромптПодсказка - Строка - дополнительная подсказка.
//  Вложения - Массив - вложения.
//  АдресХранилища - Строка - адрес временного хранилища для помещения результата.
//  Сессия - СправочникСсылка.ИИ_СессииЧатов - сессия, для которой выполняется запрос.
//
// Возвращаемое значение:
//  Структура - результат запроса (также помещается во временное хранилище):
//   * Успешно - Булево - признак успешного выполнения.
//   * Ответ - Строка - текст ответа шлюза.
//   * СообщениеОбОшибке - Строка - описание ошибки.
//
Функция ВыполнитьЗапросКШлюзу(
		Знач АдресШлюза,
		Знач Таймаут,
		Знач ТекстВопроса,
		Знач История,
		Знач КонтекстОбъектаJSON = "",
		Знач ПромптПодсказка = "",
		Знач Вложения = Неопределено,
		Знач АдресХранилища = "",
		Знач Сессия = Неопределено) Экспорт
	
	Результат = Новый Структура("Успешно, Ответ, СообщениеОбОшибке", Ложь, "", "");
	
	Если Не ЗначениеЗаполнено(АдресШлюза) Тогда
		Результат.СообщениеОбОшибке = "Не задан адрес шлюза ИИ-ассистента.";
		ПоместитьВоВременноеХранилище(Результат, АдресХранилища);
		Возврат Результат;
	КонецЕсли;
	
	Если Таймаут = 0 Тогда
		Таймаут = 30;
	КонецЕсли;
	
	ПараметрыСоединения = РазобратьАдресШлюза(АдресШлюза);
	Если ПараметрыСоединения.Порт = 0 Тогда
		Результат.СообщениеОбОшибке = "Некорректный адрес шлюза: " + АдресШлюза;
		ПоместитьВоВременноеХранилище(Результат, АдресХранилища);
		Возврат Результат;
	КонецЕсли;
	
	ТелоЗапроса = СформироватьТелоЗапроса(
		ТекстВопроса, История, КонтекстОбъектаJSON, ПромптПодсказка, Вложения);
	
	Попытка
		HTTPСоединение = Новый HTTPСоединение(
			ПараметрыСоединения.Хост,
			ПараметрыСоединения.Порт,
			,
			,
			,
			Таймаут,
			ПараметрыСоединения.ЗащищенноеСоединение);
		
		HTTPЗапрос = Новый HTTPЗапрос("/chat/stream");
		HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json");
		HTTPЗапрос.УстановитьТелоИзСтроки(ТелоЗапроса);
		
		HTTPОтвет = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
		
		Если HTTPОтвет.КодСостояния <> 200 Тогда
			Результат.СообщениеОбОшибке = "Ошибка шлюза: код " + HTTPОтвет.КодСостояния;
			ПоместитьВоВременноеХранилище(Результат, АдресХранилища);
			Возврат Результат;
		КонецЕсли;
		
		ТелоОтвета = HTTPОтвет.ПолучитьТелоКакСтроку();
		РезультатЗапуска = РазобратьОтветПотока(ТелоОтвета);
		
		Если Не РезультатЗапуска.Успешно Тогда
			Результат.СообщениеОбОшибке = РезультатЗапуска.СообщениеОбОшибке;
			ПоместитьВоВременноеХранилище(Результат, АдресХранилища);
			Возврат Результат;
		КонецЕсли;
		
		ИдентификаторЗапроса = РезультатЗапуска.ИдентификаторЗапроса;
		
		// Опрашиваем статус до завершения.
		МаксимальноеВремяОжидания = 600; // 10 минут
		ВремяНачала = ТекущаяУниверсальнаяДатаВМиллисекундах();
		ИнтервалОпроса = 1; // секунда
		
		Пока Истина Цикл
			
			ВремяПрошло = (ТекущаяУниверсальнаяДатаВМиллисекундах() - ВремяНачала) / 1000;
			Если ВремяПрошло > МаксимальноеВремяОжидания Тогда
				Результат.СообщениеОбОшибке = "Превышено максимальное время ожидания ответа от шлюза.";
				Прервать;
			КонецЕсли;
			
			HTTPЗапросСтатуса = Новый HTTPЗапрос("/chat/status/" + ИдентификаторЗапроса);
			HTTPОтветСтатуса = HTTPСоединение.Получить(HTTPЗапросСтатуса);
			
			Если HTTPОтветСтатуса.КодСостояния <> 200 Тогда
				Результат.СообщениеОбОшибке = "Ошибка получения статуса: код " + HTTPОтветСтатуса.КодСостояния;
				Прервать;
			КонецЕсли;
			
			РезультатСтатуса = РазобратьСтатусЗапроса(
				HTTPОтветСтатуса.ПолучитьТелоКакСтроку());
			
			Если Не РезультатСтатуса.Успешно Тогда
				Результат.СообщениеОбОшибке = РезультатСтатуса.СообщениеОбОшибке;
				Прервать;
			КонецЕсли;
			
			Если РезультатСтатуса.Завершено Тогда
				Результат.Успешно = Истина;
				Результат.Ответ = РезультатСтатуса.Ответ;
				Прервать;
			КонецЕсли;
			
			// Пауза перед следующим опросом статуса.
			ВызватьПаузу(ИнтервалОпроса * 1000);
			
		КонецЦикла;
		
	Исключение
		Результат.СообщениеОбОшибке = "Ошибка при обращении к шлюзу: " + ОбработкаОшибок.ПредставлениеОшибкиДляПользователя(ИнформацияОбОшибке());
	КонецПопытки;
	
	ПоместитьВоВременноеХранилище(Результат, АдресХранилища);
	
	Возврат Результат;
	
КонецФункции

// Возвращает историю сообщений сессии.
//
// Параметры:
//  Сессия - СправочникСсылка.ИИ_СессииЧатов - сессия чата.
//
// Возвращаемое значение:
//  ТаблицаЗначений - история сообщений с колонками Роль, ТекстСообщения, ИдентификаторСообщения, ДатаСообщения.
//
Функция ПолучитьИсториюСессии(Знач Сессия) Экспорт
	
	Возврат РегистрыСведений.ИИ_ИсторияЧатов.ИсторияСессии(Сессия);
	
КонецФункции

// Возвращает историю сообщений сессии в формате для отправки в шлюз.
// Количество сообщений ограничено константой ИИ_МаксимальноеКоличествоСообщенийКонтекста.
//
// Параметры:
//  Сессия - СправочникСсылка.ИИ_СессииЧатов - сессия чата.
//
// Возвращаемое значение:
//  Массив - элементы Структура("role, content").
//
Функция ПолучитьИсториюСессииДляШлюза(Знач Сессия) Экспорт
	
	Результат = Новый Массив;
	История = ПолучитьИсториюСессии(Сессия);
	
	МаксимальноеКоличество = Константы.ИИ_МаксимальноеКоличествоСообщенийКонтекста.Получить();
	Если МаксимальноеКоличество = 0 Тогда
		МаксимальноеКоличество = 20;
	КонецЕсли;
	
	НачальныйИндекс = 0;
	Если История.Количество() > МаксимальноеКоличество Тогда
		НачальныйИндекс = История.Количество() - МаксимальноеКоличество;
	КонецЕсли;
	
	Для Индекс = НачальныйИндекс По История.Количество() - 1 Цикл
		Сообщение = История[Индекс];
		Роль = ?(Сообщение.Роль = Перечисления.ИИ_РолиСообщений.Ассистент, "assistant", "user");
		Результат.Добавить(Новый Структура("role, content", Роль, Сообщение.ТекстСообщения));
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Сохраняет сообщение в истории.
//
// Параметры:
//  Сессия - СправочникСсылка.ИИ_СессииЧатов - сессия чата.
//  Роль - ПеречислениеСсылка.ИИ_РолиСообщений - роль сообщения.
//  ТекстСообщения - Строка - текст сообщения.
//  ДатаСообщения - Дата - дата и время сообщения (по умолчанию текущая дата сеанса).
//
Процедура СохранитьСообщение(Знач Сессия, Знач Роль, Знач ТекстСообщения, Знач ДатаСообщения = Неопределено) Экспорт
	
	РегистрыСведений.ИИ_ИсторияЧатов.ДобавитьСообщение(Сессия, Роль, ТекстСообщения, ДатаСообщения);
	
КонецПроцедуры

// Проверяет, есть ли сообщения в сессии.
//
// Параметры:
//  Сессия - СправочникСсылка.ИИ_СессииЧатов - сессия чата.
//
// Возвращаемое значение:
//  Булево - Истина, если в сессии есть сообщения.
//
Функция ЕстьСообщенияВСессии(Знач Сессия) Экспорт
	
	Возврат РегистрыСведений.ИИ_ИсторияЧатов.ЕстьСообщенияВСессии(Сессия);
	
КонецФункции

// Удаляет сессию и всю её историю.
//
// Параметры:
//  Сессия - СправочникСсылка.ИИ_СессииЧатов - удаляемая сессия.
//
Процедура УдалитьСессию(Знач Сессия) Экспорт
	
	РегистрыСведений.ИИ_ИсторияЧатов.УдалитьИсториюСессии(Сессия);
	
	СессияОбъект = Сессия.ПолучитьОбъект();
	Если СессияОбъект <> Неопределено Тогда
		СессияОбъект.Удалить();
	КонецЕсли;
	
КонецПроцедуры

// Возвращает список сессий пользователя.
//
// Параметры:
//  Пользователь - Строка - имя пользователя. Если не указано, используется текущий пользователь.
//  Контекстный - Булево, Неопределено - отбирать только контекстные (Истина), только неконтекстные (Ложь) или все (Неопределено).
//  ОбъектКонтекста - ОпределяемыйТип.ИИ_ТипыОбъектовКонтекстныхЗапросов - объект контекста.
//      Если указан, отбираются сессии с таким же объектом.
//
// Возвращаемое значение:
//  ТаблицаЗначений - сессии с колонками Сессия, Наименование, ДатаСоздания.
//
Функция ПолучитьСписокСессий(
		Знач Пользователь = Неопределено,
		Знач Контекстный = Неопределено,
		Знач ОбъектКонтекста = Неопределено) Экспорт
	
	Если Пользователь = Неопределено Тогда
		Пользователь = ИмяПользователя();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|   ИИ_СессииЧатов.Ссылка КАК Сессия,
		|   ИИ_СессииЧатов.Наименование КАК Наименование,
		|   ИИ_СессииЧатов.Код КАК Код
		|ИЗ
		|   Справочник.ИИ_СессииЧатов КАК ИИ_СессииЧатов
		|ГДЕ
		|   ИИ_СессииЧатов.Пользователь = &Пользователь
		|   И НЕ ИИ_СессииЧатов.ПометкаУдаления
		|   И (&Контекстный = НЕОПРЕДЕЛЕНО
		|       ИЛИ ИИ_СессииЧатов.Контекстный = &Контекстный)
		|   И (&ОбъектКонтекста = НЕОПРЕДЕЛЕНО
		|       ИЛИ ИИ_СессииЧатов.ОбъектКонтекста = &ОбъектКонтекста)
		|
		|УПОРЯДОЧИТЬ ПО
		|   Код УБЫВ";
	
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	Запрос.УстановитьПараметр("Контекстный", Контекстный);
	Запрос.УстановитьПараметр("ОбъектКонтекста", ОбъектКонтекста);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Формирует HTML для отображения истории сообщений.
//
// Параметры:
//  История - ТаблицаЗначений - история сообщений с колонками Роль, ТекстСообщения, ИдентификаторСообщения, ДатаСообщения.
//  ПоказыватьИндикаторЗагрузки - Булево - если Истина, в конец выводится индикатор ожидания.
//  ФразаОжидания - Строка - фраза, выводимая в индикаторе загрузки.
//  ТекстОшибки - Строка - текст ошибки для вывода в конце истории.
//  ТекстДляПовтора - Строка - исходный текст вопроса для кнопки "Повторить".
//
// Возвращаемое значение:
//  Строка - HTML-текст.
//
Функция СформироватьHTMLСообщений(
		Знач История,
		Знач ПоказыватьИндикаторЗагрузки = Ложь,
		Знач ФразаОжидания = "",
		Знач ТекстОшибки = "",
		Знач ТекстДляПовтора = "") Экспорт
	
	Тело = СформироватьТелоHTMLСообщений(История, ПоказыватьИндикаторЗагрузки, ФразаОжидания, ТекстОшибки, ТекстДляПовтора);
	Возврат ОбернутьТелоВHTMLДокумент(Тело);
	
КонецФункции

// Формирует только тело HTML-сообщений (без обёртки <html>/<body>), которое можно
// встраивать в существующий документ или склеивать с другими фрагментами.
//
// Параметры:
//  История - ТаблицаЗначений - история сообщений.
//  ПоказыватьИндикаторЗагрузки - Булево - выводить индикатор ожидания.
//  ФразаОжидания - Строка - фраза для индикатора.
//  ТекстОшибки - Строка - текст ошибки.
//  ТекстДляПовтора - Строка - текст для кнопки "Повторить".
//
// Возвращаемое значение:
//  Строка - HTML-тело.
//
Функция СформироватьТелоHTMLСообщений(
		Знач История,
		Знач ПоказыватьИндикаторЗагрузки = Ложь,
		Знач ФразаОжидания = "",
		Знач ТекстОшибки = "",
		Знач ТекстДляПовтора = "") Экспорт
	
	HTML = "";
	
	Для Каждого Сообщение Из История Цикл
		Текст = ПреобразоватьТекстВHTML(Сообщение.ТекстСообщения);
		ДатаСтрокой = Формат(Сообщение.ДатаСообщения, "ДФ='dd.MM.yyyy HH:mm'");
		
		Если Сообщение.Роль = Перечисления.ИИ_РолиСообщений.Пользователь Тогда
			HTML = HTML + "
			|<div class='message user'>
			|  <div class='message-date'>" + ДатаСтрокой + "</div>
			|  <div class='user-bubble'>" + Текст + "</div>
			|</div>";
		Иначе
			HTML = HTML + "
			|<div class='message assistant'>
			|  <div class='message-date'>" + ДатаСтрокой + "</div>
			|  <div class='assistant-text'>" + Текст + "</div>
			|  " + КнопкиПродолженияHTML(Сообщение.ТекстСообщения) + "
			|  <div class='copy' onclick='copyMessage(this)' title='Скопировать'><svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='#888' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><rect x='9' y='9' width='13' height='13' rx='2' ry='2'/><path d='M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1'/></svg></div>
			|</div>";
		КонецЕсли;
	КонецЦикла;
	
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		ТекстДляПовтораАтрибут = СтрЗаменить(СтрЗаменить(ТекстДляПовтора, Символы.ПС, " "), Символы.ВК, " ");
		HTML = HTML + "
		|<div class='message assistant'>
		|  <div class='assistant-text error-text'>" + ЭкранироватьДляHTML(ТекстОшибки) + "</div>
		|  <div class='retry-actions'>
		|    <button class='retry-btn' data-action='retry' data-text='" + ЭкранироватьДляHTML(ТекстДляПовтораАтрибут) + "'>Повторить</button>
		|  </div>
		|</div>";
	КонецЕсли;
	
	Если ПоказыватьИндикаторЗагрузки Тогда
		ТекстФразыОжидания = ?(ЗначениеЗаполнено(ФразаОжидания), ФразаОжидания, СлучайнаяФразаОжидания());
		HTML = HTML + "
		|<div class='message assistant'>
		|  <div class='assistant-text loading'>" + ТекстФразыОжидания + "</div>
		|</div>";
	КонецЕсли;
	
	Возврат HTML;
	
КонецФункции

// Обертывает тело сообщений в полноценный HTML-документ со стилями и скриптами.
//
// Параметры:
//  Тело - Строка - HTML-тело сообщений.
//
// Возвращаемое значение:
//  Строка - полный HTML-документ.
//
Функция ОбернутьТелоВHTMLДокумент(Знач Тело) Экспорт
	
	Возврат "<!DOCTYPE html>
	|<html>
	|<head>
	|<meta charset='utf-8'>
	|<style>
	|body { font-family: 'Segoe UI', sans-serif; font-size: 14px; margin: 0; padding: 10px; background: #fff; }
