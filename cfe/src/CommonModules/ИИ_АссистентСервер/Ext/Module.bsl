|.retry-btn:hover { background: #0055aa; }
	|h1, h2, h3 { margin: 12px 0 8px; font-weight: 600; }
	|h1 { font-size: 18px; }
	|h2 { font-size: 16px; }
	|h3 { font-size: 15px; }
	|ul { margin: 8px 0; padding-left: 20px; }
	|li { margin-bottom: 4px; }
	|b, strong { font-weight: 600; }
	|i, em { font-style: italic; }
	|</style>
	|</head>
	|<body>
	|<div id='messages'>" + Тело + "</div>
	|<script>
	|function copyMessage(el) {
	|    var text = '';
	|    var parent = el.parentElement;
	|    if (parent) {
	|        var textDiv = parent.querySelector('.assistant-text');
	|        if (textDiv) text = textDiv.innerText;
	|    }
	|    var copied = false;
	|    if (navigator.clipboard && navigator.clipboard.writeText) {
	|        try {
	|            navigator.clipboard.writeText(text);
	|            copied = true;
	|        } catch (e) {}
	|    } else if (window.clipboardData && window.clipboardData.setData) {
	|        try {
	|            copied = window.clipboardData.setData('Text', text);
	|        } catch (e) {}
	|    } else {
	|        var ta = document.createElement('textarea');
	|        ta.value = text;
	|        ta.style.position = 'fixed';
	|        ta.style.left = '-9999px';
	|        document.body.appendChild(ta);
	|        ta.select();
	|        try {
	|            copied = document.execCommand('copy');
	|        } catch (e) {}
	|        document.body.removeChild(ta);
	|    }
	|    if (!copied) return;
	|    el.dataset.originalSvg = el.innerHTML;
	|    el.classList.add('copied');
	|    el.innerHTML = '&#10003;';
	|    el.title = 'Скопировано';
	|    setTimeout(function() {
	|        el.classList.remove('copied');
	|        el.innerHTML = el.dataset.originalSvg || '';
	|        el.title = 'Скопировать';
	|    }, 1500);
	|}
	|function scrollToBottom() {
	|    var messages = document.getElementById('messages');
	|    if (messages && messages.lastElementChild) {
	|        try {
	|            messages.lastElementChild.scrollIntoView(false);
	|            return;
	|        } catch (e) {}
	|    }
	|    var body = document.body;
	|    if (body) {
	|        body.scrollTop = body.scrollHeight;
	|        window.scrollTo(0, body.scrollHeight);
	|    }
	|    var html = document.documentElement;
	|    if (html) html.scrollTop = html.scrollHeight;
	|}
	|document.addEventListener('DOMContentLoaded', scrollToBottom);
	|window.onload = scrollToBottom;
	|scrollToBottom();
	|setTimeout(scrollToBottom, 100);
	|setTimeout(scrollToBottom, 500);
	|setTimeout(scrollToBottom, 1000);
	|</script>
	|</body>
	|</html>";
	
КонецФункции

// Формирует HTML одного текущего ответа ассистента (только тело, без обёртки).
//
// Параметры:
//  ТекстОтвета - Строка - текст ответа.
//
// Возвращаемое значение:
//  Строка - HTML-тело сообщения.
//
Функция СформироватьHTMLТекущегоОтвета(Знач ТекстОтвета) Экспорт
	
	История = Новый ТаблицаЗначений;
	История.Колонки.Добавить("Роль");
	История.Колонки.Добавить("ТекстСообщения");
	История.Колонки.Добавить("ИдентификаторСообщения");
	История.Колонки.Добавить("ДатаСообщения");
	
	НоваяСтрока = История.Добавить();
	НоваяСтрока.Роль = Перечисления.ИИ_РолиСообщений.Ассистент;
	НоваяСтрока.ТекстСообщения = ТекстОтвета;
	НоваяСтрока.ИдентификаторСообщения = "";
	НоваяСтрока.ДатаСообщения = ТекущаяДатаСеанса();
	
	Возврат СформироватьТелоHTMLСообщений(История);
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Возвращает HTML-код кнопок продолжения, если текст сообщения содержит
// фразу о достижении лимита анализа.
//
// Параметры:
//  ТекстСообщения - Строка - исходный текст сообщения ассистента.
//
// Возвращаемое значение:
//  Строка - HTML с кнопками или пустая строка.
//
Функция КнопкиПродолженияHTML(Знач ТекстСообщения)
	
	Если СтрНайти(ТекстСообщения, "Я достиг лимита анализа") = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат "
	|<div class='continue-actions'>
	|  <button class='continue-btn' data-action='continue'>Продолжить</button>
	|  <button class='stop-btn' data-action='stop'>Завершить</button>
	|</div>";
	
КонецФункции

// Экранирует спецсимволы HTML для безопасного вывода текста и атрибутов.
//
// Параметры:
//  Текст - Строка - исходный текст.
//
// Возвращаемое значение:
//  Строка - экранированный текст.
//
Функция ЭкранироватьДляHTML(Знач Текст)
	
	Текст = СтрЗаменить(Текст, "&", "&amp;");
	Текст = СтрЗаменить(Текст, "<", "&lt;");
	Текст = СтрЗаменить(Текст, ">", "&gt;");
	Текст = СтрЗаменить(Текст, """", "&quot;");
	Текст = СтрЗаменить(Текст, "'", "&#39;");
	
	Возврат Текст;
	
КонецФункции

Функция СформироватьНаименованиеСессии(Знач ТекстСообщения, Знач ДатаСоздания) Экспорт
	
	ОчищенныйТекст = СокрЛП(ТекстСообщения);
	
	Если СтрДлина(ОчищенныйТекст) < 3 Тогда
		Возврат "Чат от " + Формат(ДатаСоздания, "ДФ='dd.MM.yyyy HH:mm:ss'");
	КонецЕсли;
	
	МаксимальнаяДлина = 50;
	Если СтрДлина(ОчищенныйТекст) > МаксимальнаяДлина Тогда
		ОчищенныйТекст = Лев(ОчищенныйТекст, МаксимальнаяДлина) + "...";
	КонецЕсли;
	
	Возврат ОчищенныйТекст;
	
КонецФункции

Функция СлучайнаяФразаОжидания()
	
	Возврат "Нагружаю видеокарты знаниями людей...";
	
КонецФункции

// Преобразует исходный текст сообщения в HTML: экранирует спецсимволы,
// заменяет переносы строк на <br>, обрабатывает markdown-таблицы, заголовки,
// списки, жирный и курсивный текст.
//
// Параметры:
//  Текст - Строка - исходный текст.
//
// Возвращаемое значение:
//  Строка - HTML-текст.
//
Функция ПреобразоватьТекстВHTML(Знач Текст)
	
	Строки = СтрРазделить(Текст, Символы.ПС, Истина);
	Результат = Новый Массив;
	
	Индекс = 0;
	Пока Индекс < Строки.Количество() Цикл
		Строка = СокрЛП(Строки[Индекс]);
		
		Если ЭтоСтрокаТаблицы(Строка) Тогда
			БлокТаблицы = Новый Массив;
			Пока Индекс < Строки.Количество() Цикл
				ТекущаяСтрока = СокрЛП(Строки[Индекс]);
				Если Не ЭтоСтрокаТаблицы(ТекущаяСтрока) Тогда
					Прервать;
				КонецЕсли;
				БлокТаблицы.Добавить(ТекущаяСтрока);
				Индекс = Индекс + 1;
			КонецЦикла;
			Результат.Добавить(ПреобразоватьБлокТаблицыВHTML(БлокТаблицы));
		ИначеЕсли УровеньЗаголовка(Строка) > 0 Тогда
			Уровень = УровеньЗаголовка(Строка);
			ТекстЗаголовка = СокрЛП(Сред(Строка, Уровень + 2));
			HTMLЗаголовка = "<h" + Уровень + ">" + ОбработатьВстроеннуюРазметку(ОбработатьСсылкиВСтроке(ТекстЗаголовка)) + "</h" + Уровень + ">";
			Результат.Добавить(HTMLЗаголовка);
			Индекс = Индекс + 1;
		ИначеЕсли ЭтоЭлементСписка(Строка) Тогда
			Результат.Добавить("<ul>");
			Пока Индекс < Строки.Количество() Цикл
				ТекущаяСтрока = СокрЛП(Строки[Индекс]);
				Если Не ЭтоЭлементСписка(ТекущаяСтрока) Тогда
					Прервать;
				КонецЕсли;
				ТекстЭлемента = СокрЛП(Сред(ТекущаяСтрока, 3));
				Результат.Добавить("<li>" + ОбработатьВстроеннуюРазметку(ОбработатьСсылкиВСтроке(ТекстЭлемента)) + "</li>");
				Индекс = Индекс + 1;
			КонецЦикла;
			Результат.Добавить("</ul>");
		Иначе
			Результат.Добавить(ОбработатьВстроеннуюРазметку(ОбработатьСсылкиВСтроке(Строки[Индекс])) + "<br>");
			Индекс = Индекс + 1;
		КонецЕсли;
	КонецЦикла;
	
	Возврат СтрСоединить(Результат, "");
	
КонецФункции

Функция ЭтоСтрокаТаблицы(Знач Строка)
	
	Если СтрДлина(Строка) < 2 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Лев(Строка, 1) = "|" И Прав(Строка, 1) = "|";
	
КонецФункции

// Определяет уровень markdown-заголовка (#, ##, ###).
// Возвращает 0, если строка не является заголовком.
//
// Параметры:
//  Строка - Строка - строка текста.
//
// Возвращаемое значение:
//  Число - уровень заголовка (1-3) или 0.
//
Функция УровеньЗаголовка(Знач Строка)
	
	Если СтрНачинаетсяС(Строка, "### ") Тогда
		Возврат 3;
	ИначеЕсли СтрНачинаетсяС(Строка, "## ") Тогда
		Возврат 2;
	ИначеЕсли СтрНачинаетсяС(Строка, "# ") Тогда
		Возврат 1;
	Иначе
		Возврат 0;
	КонецЕсли;
	
КонецФункции

// Проверяет, что строка является элементом маркированного списка.
//
// Параметры:
//  Строка - Строка - строка текста.
//
// Возвращаемое значение:
//  Булево - Истина, если строка начинается с "- " или "* ".
//
Функция ЭтоЭлементСписка(Знач Строка)
	
	Возврат СтрНачинаетсяС(Строка, "- ") Или СтрНачинаетсяС(Строка, "* ");
	
КонецФункции

// Обрабатывает встроенную markdown-разметку: жирный (** / __) и курсив (* / _).
//
// Параметры:
//  Текст - Строка - исходный текст (спецсимволы уже экранированы).
//
// Возвращаемое значение:
//  Строка - HTML с тегами <b> и <i>.
//
Функция ОбработатьВстроеннуюРазметку(Знач Текст)
	
	Текст = ЗаменитьПарныеСимволы(Текст, "**", "<b>", "</b>");
	Текст = ЗаменитьПарныеСимволы(Текст, "__", "<b>", "</b>");
	Текст = ЗаменитьПарныеСимволы(Текст, "*", "<i>", "</i>");
	Текст = ЗаменитьПарныеСимволы(Текст, "_", "<i>", "</i>");
	
	Возврат Текст;
	
КонецФункции

// Заменяет пары символов-разделителей на открывающий и закрывающий HTML-тег.
// Обрабатывает только непересекающиеся пары слева направо.
//
// Параметры:
//  Текст - Строка - исходный текст.
//  Разделитель - Строка - символы-разделители (например, "**").
//  ОткрывающийТег - Строка - открывающий HTML-тег.
//  ЗакрывающийТег - Строка - закрывающий HTML-тег.
//
// Возвращаемое значение:
//  Строка - результат замены.
//
Функция ЗаменитьПарныеСимволы(Знач Текст, Знач Разделитель, Знач ОткрывающийТег, Знач ЗакрывающийТег)
	
	ДлинаРазделителя = СтрДлина(Разделитель);
	Результат = "";
	Остаток = Текст;
	Открыт = Ложь;
	
	Пока Истина Цикл
		Позиция = СтрНайти(Остаток, Разделитель);
		Если Позиция = 0 Тогда
			Результат = Результат + Остаток;
			Прервать;
		КонецЕсли;
		
		Результат = Результат + Лев(Остаток, Позиция - 1);
		Результат = Результат + ?(Открыт, ЗакрывающийТег, ОткрывающийТег);
		Открыт = Не Открыт;
		
		Остаток = Сред(Остаток, Позиция + ДлинаРазделителя);
	КонецЦикла;
	
	// Если остался незакрытый открывающий тег - убираем его.
	Если Открыт Тогда
		Результат = СтрЗаменить(Результат, ОткрывающийТег, Разделитель);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Проверяет, что строка является разделителем markdown-таблицы.
// Допустимые символы: |, -, :, пробел.
//
// Параметры:
//  Строка - Строка - строка таблицы.
//
// Возвращаемое значение:
//  Булево - Истина, если строка - разделитель.
//
Функция ЭтоСтрокаРазделитель(Знач Строка)
	
	Для Индекс = 1 По СтрДлина(Строка) Цикл
		Символ = Сред(Строка, Индекс, 1);
		Если Символ <> "|" И Символ <> "-" И Символ <> ":" И Символ <> " " Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Возврат СтрНайти(Строка, "-") > 0;
	
КонецФункции

Функция ПреобразоватьБлокТаблицыВHTML(Знач БлокТаблицы)
	
	Если БлокТаблицы.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	ЕстьЗаголовок = Ложь;
	НачальныйИндексДанных = 0;
	
	Если БлокТаблицы.Количество() >= 2 Тогда
		ВтораяСтрока = БлокТаблицы[1];
		Если ЭтоСтрокаРазделитель(ВтораяСтрока) Тогда
			ЕстьЗаголовок = Истина;
			НачальныйИндексДанных = 2;
		КонецЕсли;
	КонецЕсли;
	
	HTML = "<table class='md-table'>";
	
	Если ЕстьЗаголовок Тогда
		HTML = HTML + "<thead><tr>";
		ЯчейкиЗаголовка = РазобратьСтрокуТаблицы(БлокТаблицы[0]);
		Для Каждого Ячейка Из ЯчейкиЗаголовка Цикл
			HTML = HTML + "<th>" + Ячейка + "</th>";
		КонецЦикла;
		HTML = HTML + "</tr></thead>";
	КонецЕсли;
	
	HTML = HTML + "<tbody>";
	
	Для Индекс = НачальныйИндексДанных По БлокТаблицы.Количество() - 1 Цикл
		HTML = HTML + "<tr>";
		Ячейки = РазобратьСтрокуТаблицы(БлокТаблицы[Индекс]);
		Для Каждого Ячейка Из Ячейки Цикл
			HTML = HTML + "<td>" + Ячейка + "</td>";
		КонецЦикла;
		HTML = HTML + "</tr>";
	КонецЦикла;
	
	HTML = HTML + "</tbody></table>";
	
	Возврат HTML;
	
КонецФункции

Функция РазобратьСтрокуТаблицы(Знач Строка)
	
	Ячейки = Новый Массив;
	Части = СтрРазделить(Строка, "|", Истина);
	
	// Первый и последний элементы пустые из-за ведущего и замыкающего разделителя.
	Для Индекс = 1 По Части.Количество() - 2 Цикл
		Ячейки.Добавить(ОбработатьСсылкиВСтроке(СокрЛП(Части[Индекс])));
	КонецЦикла;
	
	Возврат Ячейки;
	
КонецФункции

// Ищет в строке HTTP/HTTPS-ссылки и оборачивает их в HTML-ссылки.
// Остальной текст экранируется.
//
// Параметры:
//  Текст - Строка - исходная строка.
//
// Возвращаемое значение:
//  Строка - HTML с активными ссылками.
//
Функция ОбработатьСсылкиВСтроке(Знач Текст)
	
	Результат = "";
	Остаток = Текст;
	
	Пока Истина Цикл
		
		ПозицияHTTP = СтрНайти(Остаток, "http://");
		ПозицияHTTPS = СтрНайти(Остаток, "https://");
		
		Если ПозицияHTTP = 0 И ПозицияHTTPS = 0 Тогда
			Результат = Результат + ЭкранироватьHTML(Остаток);
			Прервать;
		КонецЕсли;
		
		Если ПозицияHTTP = 0 Или (ПозицияHTTPS > 0 И ПозицияHTTPS < ПозицияHTTP) Тогда
			Позиция = ПозицияHTTPS;
		Иначе
			Позиция = ПозицияHTTP;
		КонецЕсли;
		
		Результат = Результат + ЭкранироватьHTML(Лев(Остаток, Позиция - 1));
		
		Хвост = Сред(Остаток, Позиция);
		URL = ИзвлечьURL(Хвост);
		
		Если ЗначениеЗаполнено(URL) Тогда
			Результат = Результат + "<a href='" + ЭкранироватьHTML(URL) + "' target='_blank'>" + ЭкранироватьHTML(URL) + "</a>";
			Остаток = Сред(Хвост, СтрДлина(URL) + 1);
		Иначе
			// Не удалось выделить URL - выводим как есть и выходим, чтобы избежать зацикливания.
			Результат = Результат + ЭкранироватьHTML(Хвост);
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Выделяет URL из начала строки, ограничивая его пробельными символами
// и символами, которые не могут входить в URL.
//
// Параметры:
//  Текст - Строка - строка, начинающаяся с http:// или https://.
//
// Возвращаемое значение:
//  Строка - выделенный URL.
//
Функция ИзвлечьURL(Знач Текст)
	
	СимволыОкончания = " " + Символы.Таб + Символы.ПС + Символы.ВК + "<>""')]}";
	
	Для Индекс = 1 По СтрДлина(Текст) Цикл
		Символ = Сред(Текст, Индекс, 1);
		Если СтрНайти(СимволыОкончания, Символ) > 0 Тогда
			Возврат Лев(Текст, Индекс - 1);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Текст;
	
КонецФункции

Функция ЭкранироватьHTML(Знач Текст)
	
	Текст = СтрЗаменить(Текст, "&", "&amp;");
	Текст = СтрЗаменить(Текст, "<", "&lt;");
	Текст = СтрЗаменить(Текст, ">", "&gt;");
	Текст = СтрЗаменить(Текст, """", "&quot;");
	Текст = СтрЗаменить(Текст, "'", "&#x27;");
	
	Возврат Текст;
	
КонецФункции

#КонецОбласти

#Область HTTPСервер

// Разбирает адрес шлюза вида "host:port", "http://host:port" или "https://host:port".
//
// Параметры:
//  АдресШлюза - Строка - адрес шлюза.
//
// Возвращаемое значение:
//  Структура - Хост, Порт, ЗащищенноеСоединение.
//
Функция РазобратьАдресШлюза(Знач АдресШлюза)
	
	Результат = Новый Структура("Хост, Порт, ЗащищенноеСоединение", АдресШлюза, 0, Неопределено);
	
	// Убираем схему http:// или https://
	Если СтрНачинаетсяС(НРег(АдресШлюза), "https://") Тогда
		Результат.ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL();
		АдресШлюза = Сред(АдресШлюза, 9);
	ИначеЕсли СтрНачинаетсяС(НРег(АдресШлюза), "http://") Тогда
		АдресШлюза = Сред(АдресШлюза, 8);
	Иначе
		// Нет схемы - используем адрес как есть.
	КонецЕсли;
	
	// Убираем trailing path
	ПозицияСлеша = СтрНайти(АдресШлюза, "/");
	Если ПозицияСлеша > 0 Тогда
		АдресШлюза = Лев(АдресШлюза, ПозицияСлеша - 1);
	КонецЕсли;
	
	// Хост:порт
	ПозицияДвоеточия = СтрНайти(АдресШлюза, ":");
	Если ПозицияДвоеточия > 0 Тогда
		Результат.Хост = Лев(АдресШлюза, ПозицияДвоеточия - 1);
		ПортСтрока = Сред(АдресШлюза, ПозицияДвоеточия + 1);
		Попытка
			Результат.Порт = Число(ПортСтрока);
		Исключение
			Результат.Порт = 0;
		КонецПопытки;
	Иначе
		Результат.Хост = АдресШлюза;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Формирует тело JSON-запроса к шлюзу ИИ-ассистента.
//
// Параметры:
//  ТекстВопроса - Строка - текст вопроса пользователя.
//  История - Массив - история сообщений.
//  КонтекстОбъектаJSON - Строка - JSON с контекстом объекта.
//  Модель - Строка - имя модели.
//  ПромптПодсказка - Строка - дополнительная подсказка.
//  Вложения - Массив - вложения.
//
// Возвращаемое значение:
//  Строка - JSON-текст.
//
Функция СформироватьТелоЗапроса(Знач ТекстВопроса, Знач История, Знач КонтекстОбъектаJSON, Знач ПромптПодсказка = "", Знач Вложения = Неопределено)
	
	Запрос = Новый Структура;
	Запрос.Вставить("question", ТекстВопроса);
	Запрос.Вставить("messages", История);
	Запрос.Вставить("context_object", КонтекстОбъектаJSON);
	Запрос.Вставить("prompt_hint", ПромптПодсказка);
	
	Если Вложения <> Неопределено И Вложения.Количество() > 0 Тогда
		МассивВложений = Новый Массив;
		Для Каждого Вложение Из Вложения Цикл
			ОписаниеВложения = Новый Структура;
			ОписаниеВложения.Вставить("file_name", Вложение.ИмяФайла);
			ОписаниеВложения.Вставить("mime_type", Вложение.MimeType);
			ОписаниеВложения.Вставить("data", Вложение.ДанныеBase64);
			МассивВложений.Добавить(ОписаниеВложения);
		КонецЦикла;
		Запрос.Вставить("attachments", МассивВложений);
	КонецЕсли;
	
	Возврат ЗаписатьЗначениеJSON(Запрос);
	
КонецФункции

// Разбирает ответ шлюза на запуск потоковой генерации.
//
// Параметры:
//  ТелоОтвета - Строка - тело ответа.
//
// Возвращаемое значение:
//  Структура - Успешно, ИдентификаторЗапроса, СообщениеОбОшибке.
//
Функция РазобратьОтветПотока(Знач ТелоОтвета)
	
	Результат = Новый Структура("Успешно, ИдентификаторЗапроса, СообщениеОбОшибке", Ложь, "", "");
	
	Попытка
		Данные = ПрочитатьЗначениеJSON(ТелоОтвета);
		
		Успешно = Ложь;
		Статус = "";
		Если (Данные.Свойство("success", Успешно) И Успешно)
			Или (Данные.Свойство("status", Статус) И Статус = "ok") Тогда
			Результат.Успешно = Истина;
			Данные.Свойство("request_id", Результат.ИдентификаторЗапроса);
		Иначе
			Сообщение = "";
			Если Данные.Свойство("error", Сообщение) Тогда
				Результат.СообщениеОбОшибке = Сообщение;
			ИначеЕсли Данные.Свойство("status", Статус) И Статус = "error" Тогда
				Результат.СообщениеОбОшибке = "Ошибка шлюза.";
			Иначе
				Результат.СообщениеОбОшибке = "Некорректный ответ шлюза.";
			КонецЕсли;
		КонецЕсли;
	Исключение
		Результат.СообщениеОбОшибке = "Ошибка разбора ответа шлюза: " + ОбработкаОшибок.ПредставлениеОшибкиДляПользователя(ИнформацияОбОшибке());
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

// Разбирает ответ шлюза на запрос статуса потоковой генерации.
//
// Параметры:
//  ТелоОтвета - Строка - тело ответа.
//
// Возвращаемое значение:
//  Структура - Успешно, Завершено, Ответ, Версия, СообщениеОбОшибке.
//
Функция РазобратьСтатусЗапроса(Знач ТелоОтвета)
	
	Результат = Новый Структура("Успешно, Завершено, Ответ, Версия", Ложь, Ложь, "", 0);
	Результат.Вставить("СообщениеОбОшибке", "");
	
	Попытка
		Данные = ПрочитатьЗначениеJSON(ТелоОтвета);
		
		Успешно = Ложь;
		Статус = "";
		Если (Данные.Свойство("success", Успешно) И Успешно)
			Или (Данные.Свойство("status", Статус) И Статус = "ok") Тогда
			Результат.Успешно = Истина;
			Данные.Свойство("done", Результат.Завершено);
			Данные.Свойство("answer", Результат.Ответ);
			Данные.Свойство("version", Результат.Версия);
		Иначе
			Сообщение = "";
			Если Данные.Свойство("error", Сообщение) Тогда
				Результат.СообщениеОбОшибке = Сообщение;
			ИначеЕсли Данные.Свойство("status", Статус) И Статус = "error" Тогда
				Результат.СообщениеОбОшибке = "Ошибка шлюза.";
			Иначе
				Результат.СообщениеОбОшибке = "Некорректный ответ шлюза.";
			КонецЕсли;
		КонецЕсли;
	Исключение
		Результат.СообщениеОбОшибке = "Ошибка разбора ответа шлюза: " + ОбработкаОшибок.ПредставлениеОшибкиДляПользователя(ИнформацияОбОшибке());
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

