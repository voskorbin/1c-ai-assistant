	|.user-bubble { display: inline-block; background: #f0f0f0; padding: 10px 14px; border-radius: 12px; max-width: 70%; text-align: left; }
|.assistant { text-align: left; }
|.assistant-text { display: inline-block; padding: 10px 14px; border: 1px solid #ddd; border-radius: 12px; background: #fafafa; max-width: 80%; }
|.assistant-text.loading { border: none; background: transparent; padding: 8px 0; }
|.message-date { font-size: 11px; color: #888; margin-bottom: 2px; }
