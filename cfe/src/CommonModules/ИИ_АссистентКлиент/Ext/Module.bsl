// Клиентский общий модуль ИИ-ассистента.
// Содержит вспомогательные процедуры для работы с формой чата.

// Показывает сообщение об ошибке пользователю.
//
// Параметры:
//  Текст - Строка - текст сообщения.
//
Процедура ПоказатьСообщениеОбОшибке(Знач Текст) Экспорт
	
	Если Не ЗначениеЗаполнено(Текст) Тогда
		Возврат;
	КонецЕсли;
	
	Оповещение = Новый ОписаниеОповещения("ОбработкаЗакрытияСообщения", ЭтотОбъект);
	ПоказатьПредупреждение(Оповещение, Текст, , "Ошибка ИИ Ассистента");
	
КонецПроцедуры

// Пустой обработчик закрытия сообщения.
//
// Параметры:
//  ДополнительныеПараметры - Произвольный - параметры, передаваемые обработчиком оповещения.
//
Процедура ОбработкаЗакрытияСообщения(ДополнительныеПараметры) Экспорт
	
КонецПроцедуры

// Открывает форму чата с привязкой к контексту объекта.
//
// Параметры:
//  ВладелецФормы - ФормаКлиентскогоПриложения, Неопределено - форма-источник (игнорируется, форма открывается без владельца).
//  ОбъектКонтекста - ЛюбаяСсылка - ссылка на объект, для которого открывается контекстный чат.
//  КонтекстОбъектаJSON - Строка - JSON с контекстом объекта (опционально).
//
Процедура ОткрытьЧатСКонтекстомОбъекта(Знач ВладелецФормы = Неопределено, Знач ОбъектКонтекста = Неопределено, Знач КонтекстОбъектаJSON = "") Экспорт
 	
 	Если ЗначениеЗаполнено(ОбъектКонтекста) И Не ЗначениеЗаполнено(КонтекстОбъектаJSON) Тогда
 		КонтекстОбъектаJSON = ИИ_АссистентСервер.ПолучитьКонтекстОбъекта(ОбъектКонтекста);
 	КонецЕсли;
 	
 	ПараметрыФормы = Новый Структура;
 	ПараметрыФормы.Вставить("ОбъектКонтекста", ОбъектКонтекста);
 	ПараметрыФормы.Вставить("КонтекстОбъектаJSON", КонтекстОбъектаJSON);
 	
 	ОткрытьФорму("Обработка.ИИ_Ассистент.Форма.ФормаЧата", ПараметрыФормы);
 	
 КонецПроцедуры
