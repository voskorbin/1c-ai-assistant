#Область ОбработчикиСобытий

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	ОбъектКонтекста = Неопределено;
	КонтекстОбъектаJSON = "";
	
	Если ТипЗнч(ПараметрКоманды) = Тип("Массив") И ПараметрКоманды.Количество() > 0 Тогда
		Значение = ПараметрКоманды[0];
	Иначе
		Значение = ПараметрКоманды;
	КонецЕсли;
	
	Если ТипЗнч(Значение) = Тип("Строка") Тогда
		// Строковый GUID передается как есть; ссылка неизвестна.
		ОбъектКонтекста = Значение;
	ИначеЕсли ЗначениеЗаполнено(Значение) Тогда
		ОбъектКонтекста = Значение;
		КонтекстОбъектаJSON = ИИ_АссистентСервер.ПолучитьКонтекстОбъекта(Значение);
	Иначе
		// Пустое значение - контекст не передается.
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОбъектКонтекста) Тогда
		ИИ_АссистентКлиент.ОткрытьЧатСКонтекстомОбъекта(ПараметрыВыполненияКоманды.Источник, ОбъектКонтекста, КонтекстОбъектаJSON);
	Иначе
		ОткрытьФорму("Обработка.ИИ_Ассистент.Форма.ФормаЧата");
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
