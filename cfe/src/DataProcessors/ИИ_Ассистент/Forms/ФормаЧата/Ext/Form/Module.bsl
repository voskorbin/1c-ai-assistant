// Возвращает случайную фразу ожидания из списка.
//
// Возвращаемое значение:
//  Строка - случайная фраза ожидания.
//
&НаКлиенте
Функция СлучайнаяФразаОжидания()
	
	Фразы = ФразыОжидания();
	Если Фразы.Количество() = 0 Тогда
		Возврат "Думаю...";
	КонецЕсли;
	
	Индекс = ТекущаяУниверсальнаяДатаВМиллисекундах() % Фразы.Количество();
	Возврат Фразы[Индекс];
	
КонецФункции
// Опрашивает статус потокового запроса к шлюзу, обновляет индикатор загру
&НаКлиенте
Процедура УстановитьКартинкуКнопкиОтправить()
	
	Если ИдетГенерация Тогда
		Элементы.Отправить.Картинка = БиблиотекаКартинок.Остановить;
	Иначе
		Элементы.Отправить.Картинка = БиблиотекаКартинок.ОтправитьСообщение;
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура УстановитьФокусВПолеВвода()
	
	ТекущийЭлемент = Элементы.ТекстСообщения;
	
КонецПроцедуры
// Возвращает пустой HTML-документ.
//
// Возвращаемое значение:
//  Строка - пустой HTML-документ.
//
&НаКлиенте
Функция ПустойHTMLДокумент()
	
	Возврат "<!DOCTYPE html><html><head><meta charset='utf-8'></head><body></body></html>";
	
КонецФункции
// Обновляет поле СообщенияHTML, склеивая историю, текущий ответ и индикатор загрузки.
//
// Параметры:
//  ФразаОжидания - Строка - фраза для индикатора загрузки.
//
&НаКлиенте
Процедура ОбновитьПолеСообщений(Знач ФразаОжидания = "")
	
	Индикатор = "";
	Если ИдетГенерация Тогда
		ТекстФразы = ?(ЗначениеЗаполнено(ФразаОжидания), ФразаОжидания, СлучайнаяФразаОжидания());
		Индикатор = "<div class='message assistant'><div class='assistant-text loading'>" + ТекстФразы + "</div></div>";
	КонецЕсли;
	
	СообщенияHTML = ОбернутьТелоВHTMLДокументНаКлиенте(ИсторияHTML + ТекущийОтветHTML + Индикатор);
	
КонецПроцедуры
#КонецОбласти
#Область СлужебныеПроцедурыИФункции_Сервер
&НаСервереБезКонтекста
Функция ПолучитьИсториюСессииДляШлюзаНаСервере(Знач Сессия)
	
	Возврат ИИ_АссистентСервер.ПолучитьИсториюСессииДляШлюза(Сессия);
	
КонецФункции
&НаСервереБезКонтекста
Функция ПолучитьИсториюСессииДляHTMLНаСервере(
	Знач Сессия,
	Знач ТекстАссистента,
	Знач ПоказыватьИндикаторЗагрузки = Ложь,
	Знач ФразаОжидания = "",
	Знач ТекстОшибки = "",
	Знач ТекстДляПовтора = "")
	
	История = ИИ_АссистентСервер.ПолучитьИсториюСессии(Сессия);
	
	Если ЗначениеЗаполнено(ТекстАссистента) Тогда
		НоваяСтрока = История.Добавить();
		НоваяСтрока.Роль = Перечисления.ИИ_РолиСообщений.Ассистент;
		НоваяСтрока.ТекстСообщения = ТекстАссистента;
		НоваяСтрока.ИдентификаторСообщения = "pending";
		НоваяСтрока.ДатаСообщения = ТекущаяДатаСеанса();
	КонецЕсли;
	
	Возврат ИИ_АссистентСервер.СформироватьHTMLСообщений(
		История, ПоказыватьИндикаторЗагрузки, ФразаОжидания, ТекстОшибки, ТекстДляПовтора);
	
КонецФункции
&НаСервереБезКонтекста
Функция ЕстьСообщенияВСессииНаСервере(Знач Сессия)
	
	Возврат ИИ_АссистентСервер.ЕстьСообщенияВСессии(Сессия);
	
КонецФункции
&НаСервереБезКонтекста
Функция ЕстьСообщениеПользователяВСессииНаСервере(Знач Сессия, Знач ТекстСообщения)
	
	Возврат РегистрыСведений.ИИ_ИсторияЧатов.ЕстьСообщениеПользователя(Сессия, ТекстСообщения);
	
КонецФункции
&НаСервереБезКонтекста
Процедура СохранитьСообщениеПользователяНаСервере(Знач Сессия, Знач ТекстСообщения)
	
	ИИ_АссистентСервер.СохранитьСообщение(Сессия, Перечисления.ИИ_РолиСообщений.Пользователь, ТекстСообщения);
	
	Если ЭтоПервоеСообщениеПользователя(Сессия) Тогда
		НовоеНаименование = ИИ_АссистентСервер.СформироватьНаименованиеСессии(ТекстСообщения, ТекущаяДатаСеанса());
		СохранитьНаименованиеСессииНаСервере(Сессия, НовоеНаименование);
	КонецЕсли;
	
КонецПроцедуры
&НаСервереБезКонтекста
Функция ЭтоПервоеСообщениеПользователя(Знач Сессия)
	
	Возврат РегистрыСведений.ИИ_ИсторияЧатов.ЭтоПервоеСообщениеПользователя(Сессия);
	
КонецФункции
&НаСервереБезКонтекста
Процедура СохранитьНаименованиеСессииНаСервере(Знач Сессия, Знач Наименование)
	
	Если Не ЗначениеЗаполнено(Сессия) Тогда
		Возврат;
	КонецЕсли;
	
	СессияОбъект = Сессия.ПолучитьОбъект();
	Если СессияОбъект = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СессияОбъект.Наименование = Наименование;
	СессияОбъект.Записать();
	
КонецПроцедуры
&НаСервереБезКонтекста
Процедура СохранитьФинальноеСообщениеНаСервере(Знач Сессия, Знач ТекстСообщения)
	
	ИИ_АссистентСервер.СохранитьСообщение(Сессия, Перечисления.ИИ_РолиСообщений.Ассистент, ТекстСообщения);
	
КонецПроцедуры
&НаСервере
Процедура ЗагрузитьСписокСессий()
	
	СписокСессий.Очистить();
	ТаблицаСессий = ИИ_АссистентСервер.ПолучитьСписокСессий(,
		Контекстный,
		ОбъектКонтекста);
	
	Для Каждого Строка Из ТаблицаСессий Цикл
		НоваяСтрока = СписокСессий.Добавить();
		НоваяСтрока.Сессия = Строка.Сессия;
		НоваяСтрока.Наименование = Строка.Наименование;
	КонецЦикла;
	
КонецПроцедуры
&НаСервере
Процедура ЗагрузитьКонтекстСессии(Знач Сессия)
	
	Если Не ЗначениеЗаполнено(Сессия) Тогда
		Возврат;
	КонецЕсли;
	
	ОбъектКонтекста = Сессия.ОбъектКонтекста;
	КонтекстОбъектаJSON = Сессия.КонтекстОбъектаJSON;
	Контекстный = ЗначениеЗаполнено(ОбъектКонтекста)
		Или ЗначениеЗаполнено(КонтекстОбъектаJSON);
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьИсториюСессии()
	
	Если Не ЗначениеЗаполнено(ТекущаяСессия) Тогда
		ИсторияHTML = "";
		ТекущийОтветHTML = "";
		СообщенияHTML = "<!DOCTYPE html><html><head><meta charset='utf-8'></head><body></body></html>";
		Возврат;
	КонецЕсли;
	
	История = ИИ_АссистентСервер.ПолучитьИсториюСессии(ТекущаяСессия);
	ИсторияHTML = ИИ_АссистентСервер.СформироватьТелоHTMLСообщений(История);
	
	Если Не (ИдетГенерация И ТекущаяСессия = СессияТекущегоЗапроса) Тогда
		ТекущийОтветHTML = "";
	КонецЕсли;
	
	СообщенияHTML = ИИ_АссистентСервер.ОбернутьТелоВHTMLДокумент(ИсторияHTML + ТекущийОтветHTML);
	
КонецПроцедуры
&НаСервере
Процедура СоздатьНовуюСессию()
	
	ТекущаяСессия = ИИ_АссистентСервер.СоздатьСессию(
		"", КонтекстОбъектаJSON, ОбъектКонтекста);
	ЗагрузитьСписокСессий();
	ЗагрузитьИсториюСессии();
	ОбновитьЗаголовокКонтекста();
	
КонецПроцедуры
