#Область ОписаниеПеременных

// Хранит текст последнего вопроса пользователя для возможности повтора запроса.
&НаКлиенте
Перем ТекстПоследнегоВопроса;

#КонецОбласти
#Область ОбработчикиСобытийФормы
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	АдресШлюза = Константы.ИИ_АдресШлюза.Получить();
	ТаймаутЗапроса = Константы.ИИ_ТаймаутЗапроса.Получить();
	ИнтервалОпроса = Константы.ИИ_ИнтервалОпроса.Получить();
	Если ИнтервалОпроса < 2 Тогда
		ИнтервалОпроса = 2;
	КонецЕсли;
	МаксимальныйРазмерВложения = Константы.ИИ_МаксимальныйРазмерВложения.Получить();
	Если МаксимальныйРазмерВложения = 0 Тогда
		МаксимальныйРазмерВложения = 10;
	КонецЕсли;
	МаксимальноеКоличествоСообщенийКонтекста = Константы.ИИ_МаксимальноеКоличествоСообщенийКонтекста.Получить();
	Если МаксимальноеКоличествоСообщенийКонтекста = 0 Тогда
		МаксимальноеКоличествоСообщенийКонтекста = 20;
	КонецЕсли;
	ПромптПодсказка = РегистрыСведений.ИИ_НастройкиПользователей.ПолучитьПромптПодсказкуПользователя();
	HTMLДокументШаблон = ПолучитьШаблонHTMLДокументаНаСервере();
	
	Если Параметры.Свойство("ОбъектКонтекста") Тогда
		ОбъектКонтекста = Параметры.ОбъектКонтекста;
	КонецЕсли;
	Если Параметры.Свойство("КонтекстОбъектаJSON") Тогда
		КонтекстОбъектаJSON = Параметры.КонтекстОбъектаJSON;
	КонецЕсли;
	
	Если Параметры.Свойство("Сессия") И ЗначениеЗаполнено(Параметры.Сессия) Тогда
		ТекущаяСессия = Параметры.Сессия;
		ЗагрузитьКонтекстСессии(ТекущаяСессия);
	Иначе
		Контекстный = ЗначениеЗаполнено(ОбъектКонтекста)
			Или ЗначениеЗаполнено(КонтекстОбъектаJSON);
	КонецЕсли;
	
	ЗагрузитьСписокСессий();
	
	Если Не ЗначениеЗаполнено(ТекущаяСессия) Тогда
		Если СписокСессий.Количество() = 0 Тогда
			СоздатьНовуюСессию();
			Возврат;
		Иначе
			ТекущаяСессия = СписокСессий[0].Сессия;
		КонецЕсли;
	КонецЕсли;
	
	Контекстный = ЗначениеЗаполнено(ОбъектКонтекста)
		Или ЗначениеЗаполнено(КонтекстОбъектаJSON);
	
	ЗагрузитьИсториюСессии();
	ОбновитьЗаголовокКонтекста();
	
КонецПроцедуры
&НаКлиенте
Процедура ОбработкаПриОткрытии(Отказ)
	
	УстановитьКартинкуКнопкиОтправить();
	УстановитьТекущуюСессиюВСписке();
	ОбновитьОтображениеВложений();
	
КонецПроцедуры
&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	// При закрытии формы принудительно завершаем активный запрос к шлюзу,
	// чтобы не оставлять висящую генерацию на сервере.
	ОстановитьГенерацию();
	
КонецПроцедуры
&НаКлиенте
Процедура УстановитьТекущуюСессиюВСписке()
	
	Если СписокСессий.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ВосстановитьТекущуюСтрокуСписка(ТекущаяСессия);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьЗаголовокКонтекста()
	
	Если Не Контекстный Тогда
		Заголовок = "ИИ Ассистент";
		Возврат;
	КонецЕсли;
	
	ПредставлениеКонтекста = "Контекст объекта";
	Если ЗначениеЗаполнено(КонтекстОбъектаJSON) Тогда
		Попытка
			ЧтениеJSON = Новый ЧтениеJSON;
			ЧтениеJSON.УстановитьСтроку(КонтекстОбъектаJSON);
			ДанныеКонтекста = ПрочитатьJSON(ЧтениеJSON);
			Если ДанныеКонтекста.Свойство("presentation") Тогда
				ПредставлениеКонтекста = ДанныеКонтекста.presentation;
			КонецЕсли;
			Если ДанныеКонтекста.Свойство("synonym") И ЗначениеЗаполнено(ДанныеКонтекста.synonym) Тогда
				ПредставлениеКонтекста = ПредставлениеКонтекста + " (" + ДанныеКонтекста.synonym + ")";
			ИначеЕсли ДанныеКонтекста.Свойство("name") И ЗначениеЗаполнено(ДанныеКонтекста.name) Тогда
				ПредставлениеКонтекста = ПредставлениеКонтекста + " (" + ДанныеКонтекста.name + ")";
			Иначе
				// Дополнительная информация о типе объекта не указана.
			КонецЕсли;
		Исключение
			ПредставлениеКонтекста = "Контекст объекта";
		КонецПопытки;
	КонецЕсли;
	
	Заголовок = "ИИ Ассистент - " + ПредставлениеКонтекста;
	
КонецПроцедуры
&НаКлиенте
Процедура ОткрытьСессию(Знач Сессия) Экспорт
	
	Если Не ЗначениеЗаполнено(Сессия) Тогда
		Возврат;
	КонецЕсли;
	
	ОбновитьСписокСессийНаКлиенте();
	ТекущаяСессия = Сессия;
	ВосстановитьТекущуюСтрокуСписка(ТекущаяСессия);
	ЗагрузитьИсториюСессии();
	УстановитьФокусВПолеВвода();
	
КонецПроцедуры
#КонецОбласти
#Область ОбработчикиСобытийЭлементовШапкиФормы
&НаКлиенте
Процедура НаименованиеПриИзменении(Элемент)
	
	ДанныеТекущейСтроки = Элементы.СписокСессий.ТекущиеДанные;
	Если ДанныеТекущейСтроки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	НовоеНаименование = СокрЛП(ДанныеТекущейСтроки.Наименование);
	Если Не ЗначениеЗаполнено(НовоеНаименование) Тогда
		ЗагрузитьСписокСессий();
		Возврат;
	КонецЕсли;
	
	СохранитьНаименованиеСессииНаСервере(ДанныеТекущейСтроки.Сессия, НовоеНаименование);
	
КонецПроцедуры
&НаКлиенте
Процедура СообщенияHTMLПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если ДанныеСобытия = Неопределено Или Не ДанныеСобытия.Свойство("Element") Тогда
		Возврат;
	КонецЕсли;
	
	ЭлементHTML = ДанныеСобытия.Element;
	Если ЭлементHTML = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Действие = НайтиАтрибутВИерархии(ЭлементHTML, "data-action");
	Если ЗначениеЗаполнено(Действие) Тогда
		Если Действие = "continue" Тогда
			ОтправитьСообщениеПользователя("продолжай");
		ИначеЕсли Действие = "retry" Тогда
			ТекстДляПовтора = НайтиАтрибутВИерархии(ЭлементHTML, "data-text");
			Если Не ЗначениеЗаполнено(ТекстДляПовтора) Тогда
				ТекстДляПовтора = ТекстПоследнегоВопроса;
			КонецЕсли;
			Если ЗначениеЗаполнено(ТекстДляПовтора) Тогда
				ОтправитьСообщениеПользователя(ТекстДляПовтора, Истина);
			КонецЕсли;
		Иначе
			// Действие не распознано - игнорируем.
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	Идентификатор = НайтиАтрибутВИерархии(ЭлементHTML, "data-copy-id");
	Если Не ЗначениеЗаполнено(Идентификатор) Тогда
		Возврат;
	КонецЕсли;
	
	ТекстСообщенияДляКопирования = НайтиТекстСообщенияПоИдентификатору(ТекущаяСессия, Идентификатор);
	Если Не ЗначениеЗаполнено(ТекстСообщенияДляКопирования) Тогда
		Возврат;
	КонецЕсли;
	
	Если СредстваБуфераОбмена.ИспользованиеДоступно() Тогда
		ЭлементБуфера = Новый ЭлементБуфераОбмена(СтандартныйФорматДанныхБуфераОбмена.Текст, ТекстСообщенияДляКопирования);
		Оповещение = Новый ОписаниеОповещения("СообщенияHTMLПриНажатииЗавершениеКопирования", ЭтотОбъект);
		СредстваБуфераОбмена.НачатьПомещениеДанных(Оповещение, ЭлементБуфера);
	КонецЕсли;
	
КонецПроцедуры
// Завершение асинхронного помещения текста сообщения в буфер обмена.
//
// Параметры:
//  Результат - Булево, ИнформацияОбОшибке - результат помещения данных.
//  ДополнительныеПараметры - Произвольный - не используется.
//
&НаКлиенте
Процедура СообщенияHTMLПриНажатииЗавершениеКопирования(Результат, ДополнительныеПараметры) Экспорт
	
	// Действий после копирования не требуется.
	
КонецПроцедуры
#КонецОбласти
#Область ОбработчикиСобытийЭлементовТаблицыФормы_СписокСессий
&НаКлиенте
Процедура СписокСессийВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	УстановитьТекущуюСессиюИзСписка();
	
КонецПроцедуры
&НаКлиенте
Процедура СписокСессийПриАктивизацииСтроки(Элемент)
	
	УстановитьТекущуюСессиюИзСписка();
	
КонецПроцедуры
&НаКлиенте
Процедура УстановитьТекущуюСессиюИзСписка()
	
	Если ОбновлениеСпискаСессий Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеТекущейСтроки = Элементы.СписокСессий.ТекущиеДанные;
	Если ДанныеТекущейСтроки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ВыбраннаяСессия = ДанныеТекущейСтроки.Сессия;
	Если ВыбраннаяСессия = ТекущаяСессия Тогда
		Возврат;
	КонецЕсли;
	
	ТекущаяСессия = ВыбраннаяСессия;
	ЗагрузитьКонтекстИИсториюСессииНаСервере(ТекущаяСессия);
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьКонтекстИИсториюСессииНаСервере(Знач Сессия)
	
	ЗагрузитьКонтекстСессии(Сессия);
	ЗагрузитьИсториюСессии();
	ОбновитьЗаголовокКонтекста();
	
КонецПроцедуры
#КонецОбласти
#Область ОбработчикиКомандФормы
&НаКлиенте
Процедура НовыйЧатОбработка(Команда)
	
	СоздатьНовуюСессию();
	ВосстановитьТекущуюСтрокуСписка(ТекущаяСессия);
	УстановитьФокусВПолеВвода();
	
КонецПроцедуры
&НаКлиенте
Процедура ОтправитьСообщениеПользователя(Знач Текст, Знач ЭтоПовтор = Ложь)
	
	ТекстСообщения = Текст;
	ОтправитьОбработка(Неопределено, ЭтоПовтор);
	
КонецПроцедуры
&НаКлиенте
Процедура ОтправитьОбработка(Команда = Неопределено, Знач ЭтоПовтор = Ложь)
	
	Если ИдетГенерация Тогда
		ОстановитьГенерацию();
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекстСообщения) И Вложения.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекущаяСессия) Тогда
		СоздатьНовуюСессию();
	КонецЕсли;
	
	СессияТекущегоЗапроса = ТекущаяСессия;
	ТекстВопроса = ТекстСообщения;
	ТекстПоследнегоВопроса = ТекстВопроса;
	ТекстСообщения = "";
	УстановитьФокусВПолеВвода();
	
	Если Не ЭтоПовтор
		Или Не ЕстьСообщениеПользователяВСессииНаСервере(СессияТекущегоЗапроса, ТекстВопроса) Тогда
		СохранитьСообщениеПользователяНаСервере(СессияТекущегоЗапроса, ТекстВопроса);
	КонецЕсли;
	
	ВложенияДляОтправки = Новый Массив;
	Для Каждого СтрокаВложения Из Вложения Цикл
		ОписаниеВложения = Новый Структура("ИмяФайла, MimeType, ДанныеBase64");
		ОписаниеВложения.ИмяФайла = СтрокаВложения.ИмяФайла;
		ОписаниеВложения.MimeType = СтрокаВложения.MimeType;
		ОписаниеВложения.ДанныеBase64 = СтрокаВложения.ДанныеBase64;
		ВложенияДляОтправки.Добавить(ОписаниеВложения);
	КонецЦикла;
	
	УстановитьРежимГенерации(Истина);
	ЗагрузитьИсториюСессии();
	ОбновитьПолеСообщений();
	
	Если Не ЭтоПовтор Тогда
		ОбновитьСписокСессийНаКлиенте();
	КонецЕсли;
	
	ИсторияДляШлюза = ПолучитьИсториюСессииДляШлюзаНаСервере(СессияТекущегоЗапроса);
	
	ИдентификаторЗапроса = "";
	АдресХранилищаЗапроса = "";
	
	Попытка
		Таймаут = ?(ТаймаутЗапроса = 0, 30, ТаймаутЗапроса);
		
		ДанныеЗапуска = ИИ_АссистентСервер.ЗапуститьЗапросКШлюзу(
			АдресШлюза,
			Таймаут,
			ТекстВопроса,
			ИсторияДляШлюза,
			КонтекстОбъектаJSON,
			ПромптПодсказка,
			ВложенияДляОтправки,
			ТекущаяСессия);
		
		ИдентификаторЗапроса = ДанныеЗапуска.ИдентификаторЗадания;
		АдресХранилищаЗапроса = ДанныеЗапуска.АдресХранилища;
		
		Вложения.Очистить();
		ОбновитьОтображениеВложений();
	Исключение
		Если ИдетГенерация Тогда
			СообщенияHTML = ПолучитьИсториюСессииДляHTMLНаСервере(
				СессияТекущегоЗапроса,
				"",
				Ложь,
				"",
				"Ошибка при запуске запроса: " + ОбработкаОшибок.ПредставлениеОшибкиДляПользователя(ИнформацияОбОшибке()),
				ТекстПоследнегоВопроса);
			ЗавершитьГенерацию(Ложь);
		КонецЕсли;
		Возврат;
	КонецПопытки;
	
	// Запущено фоновое задание - подключаем регулярный опрос статуса.
	Если ИдетГенерация И ЗначениеЗаполнено(ИдентификаторЗапроса) Тогда
		ПодключитьОбработчикОжидания("ПроверитьСтатусЗапроса", ИнтервалОпроса, Ложь);
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура УдалитьСессиюОбработка(Команда)
	
	Если Не ЗначениеЗаполнено(ТекущаяСессия) Тогда
		Возврат;
	КонецЕсли;
	
	Если ЕстьСообщенияВСессииНаСервере(ТекущаяСессия) Тогда
		Оповещение = Новый ОписаниеОповещения("ПослеВопросаОбУдалении", ЭтотОбъект);
		ТекстВопроса = "В выбранной сессии есть переписка. Удалить сессию?";
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	Иначе
		ПослеВопросаОбУдалении(КодВозвратаДиалога.Да, Неопределено);
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура ПрикрепитьКартинкуОбработка(Команда)
	
	ПараметрыДиалога = Новый ПараметрыДиалогаПомещенияФайлов(
		"Выберите изображение",
		Истина,
		"Изображения|*.png;*.jpg;*.jpeg;*.gif;*.bmp;*.webp");
	
	Оповещение = Новый ОписаниеОповещения("ПослеПомещенияКартинок", ЭтотОбъект);
	НачатьПомещениеФайловНаСервер(Оповещение, Неопределено, Неопределено, ПараметрыДиалога, УникальныйИдентификатор);
	
КонецПроцедуры
// Обработчик завершения помещения выбранных изображений во временное хранилище.
// Работает в тонком клиенте и веб-клиенте.
//
// Параметры:
//  ПомещенныеФайлы - Массив, Неопределено - описания помещённых файлов или Неопределено при отмене.
//  ДополнительныеПараметры - Произвольный - дополнительные параметры обработчика оповещения.
//
&НаКлиенте
Процедура ПослеПомещенияКартинок(ПомещенныеФайлы, ДополнительныеПараметры) Экспорт
	
	Если ПомещенныеФайлы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	АдресаФайлов = Новый Массив;
	ОписанияФайлов = Новый Соответствие;
	Для Каждого ОписаниеФайла Из ПомещенныеФайлы Цикл
		Если ОписаниеФайла.ПомещениеФайлаОтменено Тогда
			Продолжить;
		КонецЕсли;
		
		АдресаФайлов.Добавить(ОписаниеФайла.Адрес);
		ОписанияФайлов.Вставить(ОписаниеФайла.Адрес, ОписаниеФайла.СсылкаНаФайл);
	КонецЦикла;
	
	Если АдресаФайлов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеВложений = ПолучитьДанныеВложенийНаСервере(АдресаФайлов);
	
	МаксимальныйРазмерБайт = МаксимальныйРазмерВложения * 1024 * 1024;
	ПревышившиеРазмер = Новый Массив;
	
	Для Каждого Элемент Из ДанныеВложений Цикл
		СсылкаНаФайл = ОписанияФайлов.Получить(Элемент.Адрес);
		Если СсылкаНаФайл = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Если МаксимальныйРазмерБайт > 0 И Элемент.Размер > МаксимальныйРазмерБайт Тогда
			ПревышившиеРазмер.Добавить(СсылкаНаФайл.Имя);
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = Вложения.Добавить();
		НоваяСтрока.ИмяФайла = СсылкаНаФайл.Имя;
		НоваяСтрока.MimeType = MimeTypeПоРасширению(СсылкаНаФайл.Расширение);
		НоваяСтрока.ДанныеBase64 = Base64ВОднуСтроку(Элемент.ДанныеBase64);
	КонецЦикла;
	
	Если ПревышившиеРазмер.Количество() > 0 Тогда
		ТекстСообщения = СтрШаблон("Следующие файлы превышают максимальный размер (%1 МБ) и не добавлены:%2%3",
			МаксимальныйРазмерВложения,
			Символы.ПС,
			СтрСоединить(ПревышившиеРазмер, Символы.ПС));
		ИИ_АссистентКлиент.ПоказатьСообщениеОбОшибке(ТекстСообщения);
	КонецЕсли;
	
	ОбновитьОтображениеВложений();
	
КонецПроцедуры

// Получает двоичные данные вложений из временного хранилища на сервере.
//
// Параметры:
//  АдресаФайлов - Массив - адреса во временном хранилище.
//
// Возвращаемое значение:
//  Массив - структуры с полями Адрес, ДанныеBase64, Размер.
//
&НаСервереБезКонтекста
Функция ПолучитьДанныеВложенийНаСервере(Знач АдресаФайлов)
	
	Результат = Новый Массив;
	Для Каждого Адрес Из АдресаФайлов Цикл
		ДвоичныеДанные = ПолучитьИзВременногоХранилища(Адрес);
		Если ДвоичныеДанные = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Результат.Добавить(Новый Структура("Адрес, ДанныеBase64, Размер",
			Адрес,
			Base64Строка(ДвоичныеДанные),
			ДвоичныеДанные.Размер()));
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции
&НаКлиенте
Функция MimeTypeПоРасширению(Знач Расширение)
	
	Расширение = НРег(Расширение);
	Если Расширение = ".png" Тогда
		Возврат "image/png";
	ИначеЕсли Расширение = ".jpg" Или Расширение = ".jpeg" Тогда
		Возврат "image/jpeg";
	ИначеЕсли Расширение = ".gif" Тогда
		Возврат "image/gif";
	ИначеЕсли Расширение = ".bmp" Тогда
		Возврат "image/bmp";
	ИначеЕсли Расширение = ".webp" Тогда
		Возврат "image/webp";
	Иначе
		Возврат "image/png";
	КонецЕсли;
	
КонецФункции
// Убирает из Base64-строки переводы строк, которые добавляет функция Base64Строка.
// API модели требует данные в одну строку без разделителей.
//
// Параметры:
//  Base64 - Строка - исходная Base64-строка с переводами строк.
//
// Возвращаемое значение:
//  Строка - Base64-строка в одну строку.
//
&НаКлиенте
Функция Base64ВОднуСтроку(Знач Base64)
	
	Возврат СтрСоединить(СтрРазделить(Base64, Символы.ПС + Символы.ВК, Ложь), "");
	
КонецФункции
&НаКлиенте
Процедура ОбновитьОтображениеВложений()
	
	КоличествоВложений = Вложения.Количество();
	Элементы.ГруппаВложенияИнфо.Видимость = (КоличествоВложений > 0);
	
	Если КоличествоВложений = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Элементы.ВложенияИнфо.Заголовок = СтрШаблон("Вложения: %1", КоличествоВложений);
	
	ИменаФайлов = Новый Массив;
	Для Каждого СтрокаВложения Из Вложения Цикл
		ИменаФайлов.Добавить(СтрокаВложения.ИмяФайла);
	КонецЦикла;
	Элементы.ВложенияИнфо.РасширеннаяПодсказка.Заголовок = СтрСоединить(ИменаФайлов, Символы.ПС);
	
КонецПроцедуры
&НаКлиенте
Процедура ОчиститьВложенияОбработка(Команда)
	
	Вложения.Очистить();
	ОбновитьОтображениеВложений();
	
КонецПроцедуры
&НаКлиенте
Процедура ПослеВопросаОбУдалении(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		УдаляемаяСессия = ТекущаяСессия;
		
		Если ИдетГенерация И УдаляемаяСессия = СессияТекущегоЗапроса Тогда
			ОстановитьГенерацию();
		КонецЕсли;
		
		ИИ_АссистентСервер.УдалитьСессию(УдаляемаяСессия);
		ТекущаяСессия = ПредопределенноеЗначение("Справочник.ИИ_СессииЧатов.ПустаяСсылка");
		ОбновитьСписокСессийНаКлиенте();
		Если СписокСессий.Количество() > 0 Тогда
			ТекущаяСессия = СписокСессий[0].Сессия;
			ВосстановитьТекущуюСтрокуСписка(ТекущаяСессия);
			ЗагрузитьИсториюСессии();
		Иначе
			ИсторияHTML = "";
			ТекущийОтветHTML = "";
			СообщенияHTML = ПустойHTMLДокумент();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры
#КонецОбласти
#Область СлужебныеПроцедурыИФункции
#Область СлужебныеПроцедурыИФункции_Клиент
&НаКлиенте
Процедура ОбновитьСписокСессийНаКлиенте()
	
	ОбновлениеСпискаСессий = Истина;
	ЗагрузитьСписокСессий();
	ВосстановитьТекущуюСтрокуСписка(ТекущаяСессия);
	ОбновлениеСпискаСессий = Ложь;
	
КонецПроцедуры
&НаКлиенте
Процедура ВосстановитьТекущуюСтрокуСписка(Знач Сессия)
	
	Для Каждого СтрокаСписка Из СписокСессий Цикл
		Если СтрокаСписка.Сессия = Сессия Тогда
			Элементы.СписокСессий.ТекущаяСтрока = СтрокаСписка.ПолучитьИдентификатор();
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры
&НаКлиенте
Процедура ОбновитьСтатус(Знач Ответ, Знач Завершено) Экспорт
	
	Если Не ЗначениеЗаполнено(СессияТекущегоЗапроса) Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекущаяСессия <> СессияТекущегоЗапроса Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Ответ) Тогда
		ТекущийОтветHTML = СформироватьHTMLТекущегоОтветаНаСервере(Ответ);
	КонецЕсли;
	ОбновитьПолеСообщений();
	
	Если Завершено Тогда
		ЗавершитьГенерацию(Ложь);
		ЗагрузитьИсториюСессии();
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Функция НайтиАтрибутВИерархии(Знач ЭлементHTML, Знач ИмяАтрибута)
	
	ТекущийЭлементHTML = ЭлементHTML;
	Пока ТекущийЭлементHTML <> Неопределено Цикл
		ЗначениеАтрибута = Неопределено;
		Попытка
			ЗначениеАтрибута = ТекущийЭлементHTML.getAttribute(ИмяАтрибута);
		Исключение
			ЗначениеАтрибута = Неопределено;
		КонецПопытки;
		Если ЗначениеЗаполнено(ЗначениеАтрибута) Тогда
			Возврат ЗначениеАтрибута;
		КонецЕсли;
		Попытка
			ТекущийЭлементHTML = ТекущийЭлементHTML.parentNode;
		Исключение
			Прервать;
		КонецПопытки;
	КонецЦикла;
	
	Возврат "";
	
КонецФункции
&НаКлиенте
Процедура ЗавершитьГенерацию(Знач ПерезагрузитьИсторию = Истина) Экспорт
	
	СброситьСостояниеГенерации();
	Если ПерезагрузитьИсторию Тогда
		ОбновитьСписокСессийНаКлиенте();
		ЗагрузитьИсториюСессии();
	КонецЕсли;
	
КонецПроцедуры
// Сбрасывает реквизиты текущего запроса и признак генерации.
// Вызывается из глобального обработчика ожидания при завершении запроса,
// даже если форма неактивна или выбран другой чат.
//
&НаКлиенте
Процедура СброситьСостояниеГенерации() Экспорт
	
	ОтключитьОбработчикОжидания("ПроверитьСтатусЗапроса");
	Если ЗначениеЗаполнено(АдресХранилищаЗапроса) Тогда
		УдалитьИзВременногоХранилища(АдресХранилищаЗапроса);
	КонецЕсли;
	ИдентификаторЗапроса = "";
	АдресХранилищаЗапроса = "";
	СессияТекущегоЗапроса = ПредопределенноеЗначение("Справочник.ИИ_СессииЧатов.ПустаяСсылка");
	УстановитьРежимГенерации(Ложь);
	
КонецПроцедуры
// Останавливает активную генерацию по команде пользователя.
// Отменяет фоновое задание и сбрасывает режим генерации.
//
&НаКлиенте
Процедура ОстановитьГенерацию()
	
	ОтключитьОбработчикОжидания("ПроверитьСтатусЗапроса");
	
	ТекущийИдентификатор = ИдентификаторЗапроса;
	ТекущийАдресХранилища = АдресХранилищаЗапроса;
	ИдентификаторЗапроса = "";
	АдресХранилищаЗапроса = "";
	СессияТекущегоЗапроса = ПредопределенноеЗначение("Справочник.ИИ_СессииЧатов.ПустаяСсылка");
	ТекущийОтветHTML = "";
	УстановитьРежимГенерации(Ложь);
	
	Если ЗначениеЗаполнено(ТекущийАдресХранилища) Тогда
		УдалитьИзВременногоХранилища(ТекущийАдресХранилища);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекущийИдентификатор) Тогда
		Возврат;
	КонецЕсли;
	
	ИИ_АссистентСервер.ОтменитьФоновоеЗадание(ТекущийИдентификатор);
	
КонецПроцедуры
// Проверяет статус фонового задания и обновляет форму при завершении.
// Вызывается через обработчик ожидания.
//
&НаКлиенте
Процедура ПроверитьСтатусЗапроса() Экспорт
	
	Если Не ИдетГенерация Или Не ЗначениеЗаполнено(ИдентификаторЗапроса) Тогда
		ОтключитьОбработчикОжидания("ПроверитьСтатусЗапроса");
		Возврат;
	КонецЕсли;
	
	Результат = ИИ_АссистентСервер.ПроверитьФоновоеЗадание(ИдентификаторЗапроса, АдресХранилищаЗапроса);
	
	Если Результат.Статус = "Выполняется" Тогда
		ОбновитьПолеСообщений();
		Возврат;
	КонецЕсли;
	
	ОтключитьОбработчикОжидания("ПроверитьСтатусЗапроса");
	ИдентификаторЗапроса = "";
	ТекущийАдресХранилища = АдресХранилищаЗапроса;
	АдресХранилищаЗапроса = "";
	
	Если ЗначениеЗаполнено(ТекущийАдресХранилища) Тогда
		УдалитьИзВременногоХранилища(ТекущийАдресХранилища);
	КонецЕсли;
	
	Если Результат.Статус = "Завершено" И Результат.Успешно Тогда
		СессияДляОповещения = СессияТекущегоЗапроса;
		СохранитьФинальноеСообщениеНаСервере(СессияТекущегоЗапроса, Результат.Ответ);
		ЗавершитьГенерацию(Истина);
		ПоказатьОповещениеПользователя(
			"Ответ готов",
			Новый ОписаниеОповещения("ОбработкаНажатияОповещения", ЭтотОбъект, Новый Структура("Сессия", СессияДляОповещения)),
			"ИИ-ассистент подготовил ответ",
			БиблиотекаКартинок.Информация,
			СтатусОповещенияПользователя.Информация);
	Иначе
		СообщениеОбОшибке = ?(ЗначениеЗаполнено(Результат.СообщениеОбОшибке),
			Результат.СообщениеОбОшибке,
			"Ошибка получения ответа от шлюза.");
		СообщенияHTML = ПолучитьИсториюСессииДляHTMLНаСервере(
			СессияТекущегоЗапроса,
			"",
			Ложь,
			"",
			СообщениеОбОшибке,
			ТекстПоследнегоВопроса);
		ЗавершитьГенерацию(Ложь);
	КонецЕсли;
	
КонецПроцедуры
// Обработчик нажатия на оповещение пользователя о полученном ответе модели.
//
// Параметры:
//  ДополнительныеПараметры - Структура - должна содержать свойство "Сессия".
//
&НаКлиенте
Процедура ОбработкаНажатияОповещения(ДополнительныеПараметры) Экспорт
	
	Если ДополнительныеПараметры = Неопределено
		Или Не ДополнительныеПараметры.Свойство("Сессия") Тогда
		Возврат;
	КонецЕсли;
	
	Сессия = ДополнительныеПараметры.Сессия;
	Если Не ЗначениеЗаполнено(Сессия) Тогда
		Возврат;
	КонецЕсли;
	
	ОткрытьСессию(Сессия);
	ЭтотОбъект.Активизировать();
	
КонецПроцедуры
&НаКлиенте
Процедура УстановитьРежимГенерации(Знач Значение)
	
	ИдетГенерация = Значение;
	Элементы.ТекстСообщения.Доступность = Не Значение;
	Элементы.ПрикрепитьКартинку.Доступность = Не Значение;
	УстановитьКартинкуКнопкиОтправить();
	
КонецПроцедуры
