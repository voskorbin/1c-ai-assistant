# -----------------------------------------------------------------------------
# Пример .env-файла для развёртывания шлюза.
# Скопируйте в ib1.env, ib2.env и т.д. и заполните реальными значениями.
# -----------------------------------------------------------------------------

# LLM-провайдер
LLM_API_KEY=your-llm-api-key

# Jira / Confluence (mcp-atlassian)
JIRA_URL=https://jira.example.com
JIRA_PERSONAL_TOKEN=your-jira-token
CONFLUENCE_URL=https://confluence.example.com
CONFLUENCE_PERSONAL_TOKEN=your-confluence-token

# MCP 1C (HTTP Basic Auth)
MCP_ONEC_USERNAME=your-mcp-username
MCP_ONEC_PASSWORD=your-mcp-onec-password

# URL репозитория с MAIN_XML для repo-sync sidecar
IB1_GIT_URL=https://gitlab.example.com/your-group/your-repo.git
